#include <sint parse_csv_line(char *line, char *fields[], int max_fields) {
    int field_count = 0;
    char *p = line;
    char *field_start = p;
    int in_quotes = 0;

    while (*p && field_count < max_fields) {
        if (*p == '"') {
            // Cambiamos estado de entrecomillado
            in_quotes = !in_quotes;
            p++;
        }
        else if (*p == ',' && !in_quotes) {
            // Fin de campo (solo si no estamos dentro de comillas)
            int len = p - field_start;
            fields[field_count] = (char*)malloc(len + 1);
            strncpy(fields[field_count], field_start, len);
            fields[field_count][len] = '\0';
            field_count++;
            field_start = p + 1; // Siguiente campo empieza después de la coma
            p++;
        }
        else {
            p++;
        }
    }

    // Último campo (después de la última coma o si no hay coma)
    if (field_count < max_fields && *field_start) {
        int len = p - field_start;
        fields[field_count] = (char*)malloc(len + 1);
        strncpy(fields[field_count], field_start, len);
        fields[field_count][len] = '\0';
        field_count++;
    }

    // Limpiar comillas externas de cada campo (si las hay)
    for (int i = 0; i < field_count; i++) {
        char *f = fields[i];
        int flen = strlen(f);
        // Si el campo empieza y termina con comillas, las quitamos
        if (flen >= 2 && f[0] == '"' && f[flen-1] == '"') {
            // Desplazamos el contenido una posición a la izquierda
            memmove(f, f + 1, flen - 2);
            f[flen - 2] = '\0'; // Nuevo final
        }
        // También podríamos manejar comillas dobles internas ("" -> ") Pero para simplificar, lo dejamos así. Si tu dataset tiene "" 
        // internos, podemos añadir un
